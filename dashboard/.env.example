# Exergy Dashboard — Environment Variables
# Copy to .env and fill in. Never commit .env.

# --- Network ---
# Public Arbitrum Sepolia RPC (override with a private endpoint for production demos)
VITE_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# --- Contract Addresses (Arbitrum Sepolia testnet) ---
# Filled in after `forge script Deploy.s.sol --broadcast` in MVP/contracts/
VITE_XRGY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
VITE_MINTING_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_ORACLE_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_SETTLEMENT_ADDRESS=0x0000000000000000000000000000000000000000

# --- Wallet Connect ---
# Get a project ID from https://cloud.walletconnect.com (free)
VITE_WALLETCONNECT_PROJECT_ID=

# --- Demo / Observer Mode ---
# When true, the dashboard runs without a connected wallet using read-only RPC + mock VPP labels.
VITE_DEMO_MODE=true
