# Exergy MVP — environment variables (testnet only).
# Copy to `.env` and fill in. NEVER commit `.env`.

# RPC endpoint for Arbitrum Sepolia. Default works but rate-limited.
ARBITRUM_SEPOLIA_RPC_URL="https://sepolia-rollup.arbitrum.io/rpc"

# Deployer private key (testnet wallet only — fund with Sepolia ETH faucet, then bridge to Arb Sepolia).
# Format: 0x-prefixed 64-hex-char string.
PRIVATE_KEY=""

# Arbiscan API key for contract verification (free at https://arbiscan.io/myapikey).
ARBISCAN_API_KEY=""

# Toggle gas reporter in test runs.
REPORT_GAS="false"
