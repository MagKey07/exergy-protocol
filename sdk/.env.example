# ─── Required for examples ───

# 0x-prefixed 64-hex private key of your VPP cloud signing wallet.
# This wallet must hold CHAINLINK_RELAYER_ROLE on OracleRouter and have
# ~0.001 ETH on Arbitrum Sepolia for gas.
VPP_CLOUD_PRIVATE_KEY=

# Label used to derive the device key deterministically (testnet only —
# see Integration Guide §3.3). Must match what was used at registration.
# Example: "smoke-vpp:device-000"
DEVICE_LABEL=smoke-vpp:device-000

# Optional — used only when VPP_CLOUD_PRIVATE_KEY is unset, to derive
# a deterministic VPP cloud wallet from a label (testnet only).
VPP_LABEL=smoke-vpp

# ─── Optional ───

# Override RPC. Defaults to https://sepolia-rollup.arbitrum.io/rpc
ARBITRUM_SEPOLIA_RPC_URL=
