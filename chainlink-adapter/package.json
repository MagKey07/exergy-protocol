{
  "name": "@exergy/chainlink-adapter",
  "version": "0.1.0",
  "private": true,
  "description": "Mock Chainlink External Adapter for Exergy Protocol — verifies dual-signed VPP packets, runs 3-of-5 consensus + DSO cross-check, then relays accepted packets on-chain to OracleRouter. One reference implementation among many; the protocol is open per CORE_THESIS.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "bin": {
    "exergy-chainlink-adapter": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "start": "node dist/index.js start",
    "dev": "ts-node src/index.ts start",
    "lint:types": "tsc --noEmit",
    "test": "node --test --import ts-node/register \"test/**/*.test.ts\""
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.19.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
